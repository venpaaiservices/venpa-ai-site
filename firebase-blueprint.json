{
  "entities": {
    "CareerApplication": {
      "title": "Career Application",
      "description": "A job application submitted through the careers form.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the applicant" },
        "email": { "type": "string", "format": "email", "description": "Email address of the applicant" },
        "phone": { "type": "string", "description": "Contact number of the applicant" },
        "experience": { "type": "string", "description": "Years of experience" },
        "location": { "type": "string", "description": "Preferred work location" },
        "currentCtc": { "type": "string", "description": "Current annual compensation" },
        "expectedCtc": { "type": "string", "description": "Expected annual compensation" },
        "resumeLink": { "type": "string", "format": "uri", "description": "Google Drive link to the applicant's resume" },
        "message": { "type": "string", "description": "Message to the hiring team" },
        "appliedAt": { "type": "string", "format": "date-time", "description": "Timestamp of when the application was submitted" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "shortlisted", "rejected"], "description": "Current status of the application" }
      },
      "required": ["fullName", "email", "phone", "experience", "location", "currentCtc", "expectedCtc", "resumeLink", "message", "appliedAt", "status"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact inquiry submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the person inquiring" },
        "email": { "type": "string", "format": "email", "description": "Email address of the person inquiring" },
        "interest": { "type": "string", "description": "Interested service or subject of the inquiry" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of when the inquiry was created" },
        "status": { "type": "string", "description": "Status of the inquiry" }
      },
      "required": ["name", "email", "interest", "message", "createdAt", "status"]
    }
  },
  "firestore": {
    "/career_applications/{applicationId}": {
      "schema": "CareerApplication",
      "description": "Collection of job applications"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of contact form inquiries"
    }
  }
}
